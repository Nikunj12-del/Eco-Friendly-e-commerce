# SERVER CONFIG
PORT=8888

# RAZORPAY (Get from Razorpay Dashboard)
RAZORPAY_KEY_ID=your_test_key_here
RAZORPAY_KEY_SECRET=your_test_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# TELEGRAM ALERTS (Optional for admin notifications)
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_chat_id_here

# FRONTEND KEYS (Must start with VITE_)
# Duplicate the Key ID here so Netlify Dev can inject it into the UI
VITE_RAZORPAY_KEY_ID=your_test_key_here

# FIREBASE (Get from Project Settings)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# SUPABASE (Get from Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key